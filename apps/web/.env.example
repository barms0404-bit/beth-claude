# --- Armstrong Arikat Research Terminal — web ---

# FastAPI backend base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase (anon key is safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Environment label — propagated to Sentry
NEXT_PUBLIC_ENVIRONMENT=development

# Sentry (leave blank to disable). NEXT_PUBLIC_* exposes to the browser bundle —
# that is correct for the client SDK. Server-only SENTRY_DSN may also be set.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
