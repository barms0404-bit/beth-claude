# --- Armstrong Arikat Research Terminal — backend ---

# Anthropic (Claude) — orchestrator + all specialists
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Polygon.io — real-time stocks tier (Stocks Advanced required for WS stream)
POLYGON_API_KEY=your-polygon-key
POLYGON_WS_URL=wss://socket.polygon.io/stocks

# FRED (Federal Reserve Economic Data) — free, sign up at fred.stlouisfed.org
FRED_API_KEY=

# Supabase — backend uses the SERVICE ROLE key (bypasses RLS)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — automated report email
RESEND_API_KEY=re_...
REPORT_FROM_EMAIL=research@armstrongarikat.com
REPORT_TO_EMAIL=brian@cccballers.com

# Scheduling — Arizona time, UTC-7, no DST
SCHEDULE_TIMEZONE=America/Phoenix

# CORS — comma-separated origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:3000

# --- Production deploy concerns ---

# Environment label used by Sentry and the health endpoint
ENVIRONMENT=development

# Sentry error tracking (leave blank to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Supabase Auth — flip REQUIRE_AUTH=true in production AFTER the login UI lands
REQUIRE_AUTH=false
SUPABASE_JWT_SECRET=

# Resend webhooks (Svix-signed) — bounce / complaint events
RESEND_WEBHOOK_SECRET=

# Public REST rate limit, slowapi syntax
RATE_LIMIT_DEFAULT=60/minute

# Macro event days — ET-local YYYY-MM-DD, comma-separated. Beth's rule:
# on FOMC / CPI / NFP days Fixed Income leads the report. NFP is detected
# algorithmically (first Friday). Fill these once a year from the public
# FOMC schedule and BLS release calendar.
FOMC_DATES=
CPI_DATES=

# Citation Enforcement Agent — strip uncited factual claims when true.
# Keep false until specialists are wired to emit citation tags.
CITATION_STRICT_MODE=false

# Temporal discipline — drives the specialist prompt instruction AND the
# Data Validator's market-hours stale-rejection threshold. One knob, both layers.
STALE_THRESHOLD_MINUTES=5
COVERAGE_GAP_DAYS=7
